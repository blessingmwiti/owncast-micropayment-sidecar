NODE_ENV=development
PORT=4000
LEDGER_FILE=data/ledger.json
PUBLIC_URL=http://localhost:4000
CREATOR_DASHBOARD_TOKEN=

# Owncast
OWNCAST_URL=http://localhost:8080
# If set, Owncast webhooks must include this value in x-payflow-webhook-secret.
OWNCAST_WEBHOOK_SECRET=

# Circle / Arc testnet
CIRCLE_API_KEY=
CIRCLE_GATEWAY_URL=https://gateway-api-testnet.circle.com
CREATOR_WALLET_ADDRESS=
ARC_TESTNET_RPC=
SETTLEMENT_PROVIDER=dry-run

# Pricing policy, in USDC per second
BASE_RATE_PER_SECOND=0.001
MIN_RATE_PER_SECOND=0.0005
MAX_RATE_PER_SECOND=0.003
