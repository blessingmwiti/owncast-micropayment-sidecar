{
  "name": "owncast-payflow",
  "version": "1.0.0",
  "description": "Per-second USDC payments for self-hosted livestreams.",
  "private": true,
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "owncast:up": "docker compose up -d owncast",
    "owncast:down": "docker compose down",
    "owncast:logs": "docker compose logs -f owncast",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "check": "npm run lint && npm run typecheck && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blessingmwiti/owncast-micropayment-sidecar.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/blessingmwiti/owncast-micropayment-sidecar/issues"
  },
  "homepage": "https://github.com/blessingmwiti/owncast-micropayment-sidecar#readme",
  "overrides": {
    "ws": "8.21.0"
  },
  "dependencies": {
    "@circle-fin/x402-batching": "^3.2.0",
    "@x402/evm": "^2.16.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
